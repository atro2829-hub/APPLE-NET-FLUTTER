        ".read": "auth != null && (data.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && (newData.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".validate": "newData.hasChildren(['userId', 'amount', 'status', 'createdAt'])",
        "userId": {
          ".validate": "newData.isString()"
        },
        "userName": {
          ".validate": "newData.isString()"
        },
        "userEmail": {
          ".validate": "newData.isString()"
        },
        "userPhone": {
          ".validate": "newData.isString()"
        },
        "bankId": {
          ".validate": "newData.isString()"
        },
        "bankName": {
          ".validate": "newData.isString()"
        },
        "amount": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "referenceNumber": {
          ".validate": "newData.isString()"
        },
        "receiptImageBase64": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'pending' || newData.val() == 'approved' || newData.val() == 'rejected')",
          ".write": "auth != null && (data.val() == 'pending' || root.child('users').child(auth.uid).child('role').val() == 'admin')"
        },
        "reviewedAt": {
          ".validate": "newData.isNumber()"
        },
        "reviewedBy": {
          ".validate": "newData.isString()"
        },
        "rejectionReason": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["userId", "status", "createdAt"]
    },

    "bankDetails": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$bankId": {
        ".validate": "newData.hasChildren(['bankName', 'accountName', 'accountNumber', 'isActive'])",
        "bankName": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "accountName": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "accountNumber": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["isActive"]
    },

    "advertisements": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$adId": {
        ".validate": "newData.hasChildren(['title', 'description', 'isActive'])",
        "title": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "description": {
          ".validate": "newData.isString()"
        },
        "imageUrl": {
          ".validate": "newData.isString()"
        },
        "linkUrl": {
          ".validate": "newData.isString()"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        },
        "order": {
          ".validate": "newData.isNumber()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["isActive"]
    },

    "homeBanners": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$bannerId": {
        ".validate": "newData.hasChildren(['title', 'isActive', 'order'])",
        "title": {
          ".validate": "newData.isString()"
        },
        "description": {
          ".validate": "newData.isString()"
        },
        "imageUrl": {
          ".validate": "newData.isString()"
        },
        "linkUrl": {
          ".validate": "newData.isString()"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        },
        "order": {
          ".validate": "newData.isNumber()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["isActive", "order"]
    },

    "starlinkProducts": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$prodId": {
        ".validate": "newData.hasChildren(['name', 'priceUSD', 'isActive', 'createdAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "description": {
          ".validate": "newData.isString()"
        },
        "priceUSD": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "quantity": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "imageBase64": {
          ".validate": "newData.isString()"
        },
        "imageUrl": {
          ".validate": "newData.isString()"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["isActive"]
    },

    "starlinkOrders": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || data.child('userId').val() == auth.uid)",
      ".write": "auth != null",
      "$orderId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || data.child('userId').val() == auth.uid)",
        ".write": "auth != null && (newData.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".validate": "newData.hasChildren(['userId', 'productId', 'priceUSD', 'status', 'createdAt'])",
        "userId": {
          ".validate": "newData.isString()"
        },
        "userName": {
          ".validate": "newData.isString()"
        },
        "userEmail": {
          ".validate": "newData.isString()"
        },
        "userPhone": {
          ".validate": "newData.isString()"
        },
        "productId": {
          ".validate": "newData.isString()"
        },
        "productName": {
          ".validate": "newData.isString()"
        },
        "priceUSD": {
          ".validate": "newData.isNumber()"
        },
        "quantity": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'pending' || newData.val() == 'confirmed' || newData.val() == 'shipped' || newData.val() == 'delivered' || newData.val() == 'cancelled')"
        },
        "address": {
          ".validate": "newData.isString()"
        },
        "notes": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["userId", "status", "createdAt"]
    },

    "subscriptionPlans": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$planId": {
        ".validate": "newData.hasChildren(['name', 'price', 'durationDays', 'isActive', 'createdAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "price": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "description": {
          ".validate": "newData.isString()"
        },
        "durationDays": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "features": {
          ".validate": "newData.isObject()"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["isActive"]
    },

    "userSubscriptions": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$subId": {
        ".read": "auth != null && (data.child('uid').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".validate": "newData.hasChildren(['planId', 'planName', 'activatedAt', 'expiresAt', 'isActive', 'uid'])",
        "planId": {
          ".validate": "newData.isString()"
        },
        "planName": {
          ".validate": "newData.isString()"
        },
        "activatedAt": {
          ".validate": "newData.isNumber()"
        },
        "expiresAt": {
          ".validate": "newData.isNumber()"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        },
        "autoRenew": {
          ".validate": "newData.isBoolean()"
        },
        "uid": {
          ".validate": "newData.isString()"
        },
        "$other": {
