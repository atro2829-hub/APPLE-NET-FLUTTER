{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        "role": {
          ".validate": "newData.isString() && (newData.val() == 'user' || newData.val() == 'admin' || newData.val() == 'network_manager')",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
        },
        "balance": {
          ".validate": "newData.isNumber() && newData.val() >= 0",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
        },
        "isActive": {
          ".validate": "newData.isBoolean()",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
        },
        "managedNetwork": {
          ".validate": "newData.isString()",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "phone": {
          ".validate": "newData.isString()"
        },
        "photoURL": {
          ".validate": "newData.isString()"
        },
        "provinceId": {
          ".validate": "newData.isString()"
        },
        "provinceName": {
          ".validate": "newData.isString()"
        },
        "district": {
          ".validate": "newData.isString()"
        },
        "fcmToken": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".read": "auth != null",
      ".indexOn": ["role", "managedNetwork", "provinceId"]
    },

    "credit": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        "amount": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "updatedAt": {
          ".validate": "newData.isNumber()"
        },
        "history": {
          "$histId": {
            ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
            ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
            ".validate": "newData.hasChildren(['type', 'amount', 'description', 'date'])",
            "type": {
              ".validate": "newData.isString() && (newData.val() == 'deposit' || newData.val() == 'purchase' || newData.val() == 'gift' || newData.val() == 'redeem' || newData.val() == 'commission' || newData.val() == 'refund')"
            },
            "amount": {
              ".validate": "newData.isNumber()"
            },
            "description": {
              ".validate": "newData.isString()"
            },
            "date": {
              ".validate": "newData.isNumber() && newData.val() > 0"
            },
            "orderId": {
              ".validate": "newData.isString()"
            },
            "depositRequestId": {
              ".validate": "newData.isString()"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      }
    },

    "notifications": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        "$notifId": {
          ".validate": "newData.hasChildren(['type', 'title', 'message', 'isRead', 'createdAt'])",
          "type": {
            ".validate": "newData.isString()"
          },
          "title": {
            ".validate": "newData.isString()"
          },
          "message": {
            ".validate": "newData.isString()"
          },
          "isRead": {
            ".validate": "newData.isBoolean()"
          },
          "createdAt": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },

    "networks": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'network_manager')",
      "$netId": {
        ".read": true,
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || (root.child('users').child(auth.uid).child('role').val() == 'network_manager' && root.child('users').child(auth.uid).child('managedNetwork').val() == $netId))",
        ".validate": "newData.hasChildren(['name', 'color', 'bgColor', 'emoji', 'createdAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "color": {
          ".validate": "newData.isString()"
        },
        "bgColor": {
          ".validate": "newData.isString()"
        },
        "emoji": {
          ".validate": "newData.isString()"
        },
        "ownerId": {
          ".validate": "newData.isString()"
        },
        "ownerName": {
          ".validate": "newData.isString()"
        },
        "ownerPhone": {
          ".validate": "newData.isString()"
        },
        "location": {
          ".validate": "newData.isString()"
        },
        "provinceId": {
          ".validate": "newData.isString()"
        },
        "provinceName": {
          ".validate": "newData.isString()"
        },
        "district": {
          ".validate": "newData.isString()"
        },
        "exactLocation": {
          ".validate": "newData.isString()"
        },
        "connectionIP": {
          ".validate": "newData.isString()"
        },
        "imageBase64": {
          ".validate": "newData.isString()"
        },
        "networkType": {
          ".validate": "newData.isString()"
        },
        "coverage": {
          ".validate": "newData.isString()"
        },
        "speed": {
          ".validate": "newData.isString()"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["provinceId", "district", "ownerId", "isActive"]
    },

    "tiers": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$tierKey": {
        ".validate": "newData.hasChildren(['tier', 'price', 'data', 'duration', 'createdAt'])",
        "tier": {
          ".validate": "newData.isString()"
        },
        "price": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "data": {
          ".validate": "newData.isString()"
        },
        "duration": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "icon": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "networkTiers": {
      ".read": true,
      "$netId": {
        ".read": true,
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || (root.child('users').child(auth.uid).child('role').val() == 'network_manager' && root.child('users').child(auth.uid).child('managedNetwork').val() == $netId))",
        "$tierId": {
          ".validate": "newData.hasChildren(['tier', 'price', 'data', 'duration', 'networkId', 'createdAt'])",
          "tier": {
            ".validate": "newData.isString()"
          },
          "price": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "data": {
            ".validate": "newData.isString()"
          },
          "duration": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "icon": {
            ".validate": "newData.isString()"
          },
          "networkId": {
            ".validate": "newData.isString() && newData.val() == $netId"
          },
          "createdAt": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },

    "cards": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'network_manager')",
      "$cardId": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || (root.child('users').child(auth.uid).child('role').val() == 'network_manager' && root.child('users').child(auth.uid).child('managedNetwork').val() == newData.child('network').val()))",
        ".validate": "newData.hasChildren(['code', 'price', 'data', 'duration', 'isUsed', 'tier', 'network', 'createdAt'])",
        "code": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "price": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "data": {
          ".validate": "newData.isString()"
        },
        "duration": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "isUsed": {
          ".validate": "newData.isBoolean()"
        },
        "usedBy": {
          ".validate": "newData.isString()"
        },
        "usedAt": {
          ".validate": "newData.isNumber()"
        },
        "tier": {
          ".validate": "newData.isString()"
        },
        "network": {
          ".validate": "newData.isString()"
        },
        "networkName": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["network", "tier", "isUsed", "usedBy", "code"]
    },

    "orders": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      ".write": "auth != null",
      "$orderId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || data.child('userId').val() == auth.uid)",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || newData.child('userId').val() == auth.uid)",
        ".validate": "newData.hasChildren(['userId', 'cardId', 'price', 'status', 'createdAt'])",
        "userId": {
          ".validate": "newData.isString()"
        },
        "cardId": {
          ".validate": "newData.isString()"
        },
        "cardCode": {
          ".validate": "newData.isString()"
        },
        "price": {
          ".validate": "newData.isNumber()"
        },
        "network": {
          ".validate": "newData.isString()"
        },
        "networkName": {
          ".validate": "newData.isString()"
        },
        "paymentMethod": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'pending' || newData.val() == 'completed' || newData.val() == 'cancelled' || newData.val() == 'refunded')"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["userId", "status", "createdAt"]
    },

    "depositRequests": {
      ".read": "auth != null",
      ".write": "auth != null",
