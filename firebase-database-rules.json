          ".validate": "newData.isString()"
        },
        "networkType": {
          ".validate": "newData.isString()"
        },
        "description": {
          ".validate": "newData.isString()"
        },
        "coverage": {
          ".validate": "newData.isString()"
        },
        "speed": {
          ".validate": "newData.isString()"
        },
        "imageBase64": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'pending' || newData.val() == 'approved' || newData.val() == 'rejected')",
          ".write": "auth != null && (data.val() == 'pending' || root.child('users').child(auth.uid).child('role').val() == 'admin')"
        },
        "reviewedAt": {
          ".validate": "newData.isNumber()"
        },
        "reviewedBy": {
          ".validate": "newData.isString()"
        },
        "rejectionReason": {
          ".validate": "newData.isString()"
        },
        "assignedNetworkId": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["userId", "status", "createdAt"]
    },

    "simCards": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$simId": {
        ".validate": "newData.hasChildren(['name', 'price', 'isAvailable'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "price": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "description": {
          ".validate": "newData.isString()"
        },
        "imageUrl": {
          ".validate": "newData.isString()"
        },
        "isAvailable": {
          ".validate": "newData.isBoolean()"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["isAvailable"]
    },

    "redeemCodes": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$codeId": {
        ".validate": "newData.hasChildren(['code', 'amount', 'isUsed', 'createdAt'])",
        "code": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "amount": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "isUsed": {
          ".validate": "newData.isBoolean()"
        },
        "usedBy": {
          ".validate": "newData.isString()"
        },
        "usedByName": {
          ".validate": "newData.isString()"
        },
        "usedAt": {
          ".validate": "newData.isNumber()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["code", "isUsed"]
    },

    "sharedRedeemCodes": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$codeId": {
        ".validate": "newData.hasChildren(['code', 'amount', 'maxRedemptions', 'isActive', 'createdAt'])",
        "code": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "amount": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "maxRedemptions": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "currentRedemptions": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "description": {
          ".validate": "newData.isString()"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["code", "isActive"]
    },

    "bulkNotifications": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$notifId": {
        ".validate": "newData.hasChildren(['title', 'message', 'type', 'sentAt'])",
        "title": {
          ".validate": "newData.isString()"
        },
        "message": {
          ".validate": "newData.isString()"
        },
        "type": {
          ".validate": "newData.isString()"
        },
        "targetCount": {
          ".validate": "newData.isNumber()"
        },
        "sentAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "commissionSettings": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'network_manager')",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$settingId": {
        ".validate": "newData.hasChildren(['managerUid', 'networkId', 'defaultRate', 'updatedAt'])",
        "managerUid": {
          ".validate": "newData.isString()"
        },
        "managerName": {
          ".validate": "newData.isString()"
        },
        "networkId": {
          ".validate": "newData.isString()"
        },
        "networkName": {
          ".validate": "newData.isString()"
        },
        "defaultRate": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
        },
        "updatedAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "commissionEntries": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'network_manager')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'network_manager')",
      "$entryId": {
        ".validate": "newData.hasChildren(['managerUid', 'networkId', 'cardPrice', 'commissionAmount', 'soldAt'])",
        "managerUid": {
          ".validate": "newData.isString()"
        },
        "managerName": {
          ".validate": "newData.isString()"
        },
        "networkId": {
          ".validate": "newData.isString()"
        },
        "networkName": {
          ".validate": "newData.isString()"
        },
        "cardId": {
          ".validate": "newData.isString()"
        },
        "cardTier": {
          ".validate": "newData.isString()"
        },
        "cardPrice": {
          ".validate": "newData.isNumber()"
        },
        "commissionRate": {
          ".validate": "newData.isNumber()"
        },
        "commissionAmount": {
          ".validate": "newData.isNumber()"
        },
        "soldAt": {
          ".validate": "newData.isNumber()"
        },
        "isPaid": {
          ".validate": "newData.isBoolean()"
        },
        "month": {
          ".validate": "newData.isString()"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["managerUid", "networkId", "isPaid", "month"]
    },

    "monthlyPayouts": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$payoutId": {
        ".validate": "newData.hasChildren(['month', 'managerUid', 'networkId', 'totalCommission', 'status', 'createdAt'])",
        "month": {
          ".validate": "newData.isString()"
        },
        "managerUid": {
          ".validate": "newData.isString()"
        },
        "managerName": {
          ".validate": "newData.isString()"
        },
        "networkId": {
          ".validate": "newData.isString()"
        },
        "networkName": {
          ".validate": "newData.isString()"
        },
        "totalCommission": {
          ".validate": "newData.isNumber()"
        },
        "totalCards": {
          ".validate": "newData.isNumber()"
        },
        "status": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "userSettings": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "security": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "purchaseAttempts": {
          "$attemptId": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          }
        }
      }
    },

    "appContent": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
    },

    "settings": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "adminWhatsApp": {
        ".validate": "newData.isString()"
      },
      "maxBalance": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "maintenanceMode": {
        ".validate": "newData.isBoolean()"
      },
      "appDownloadUrl": {
        ".validate": "newData.isString()"
      },
      "latestAppVersion": {
        ".validate": "newData.isString()"
      },
      "updateMessage": {
        ".validate": "newData.isString()"
      },
      "hiddenSections": {
        ".validate": "newData.isObject()"
      },
      "$other": {
        ".validate": false
      }
    }
  }
}
