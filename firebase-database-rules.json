          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      },
      ".indexOn": ["isActive", "provinceId"]
    },

    "networkSubmissions": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$subId": {
        ".read": "auth != null && (data.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && (newData.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".validate": "newData.hasChildren(['userId', 'networkName', 'status', 'createdAt'])",
        "userId": {
          ".validate": "newData.isString()"
        },
        "userName": {
          ".validate": "newData.isString()"
        },
        "userEmail": {
          ".validate": "newData.isString()"
        },
        "userPhone": {
          ".validate": "newData.isString()"
        },
        "networkName": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "provinceId": {
          ".validate": "newData.isString()"
        },
        "provinceName": {
          ".validate": "newData.isString()"
        },
        "district": {
          ".validate": "newData.isString()"
        },
